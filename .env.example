# HTTP Basic Auth — leave BASIC_AUTH_PASSWORD unset to skip auth in local dev
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Comma-separated list of allowed Telegram chat IDs
ALLOWED_CHAT_IDS=

# SQLite database URL
DATABASE_URL=sqlite+aiosqlite:///data/reading_list.db
